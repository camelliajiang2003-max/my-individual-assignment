        <h3 class="text-2xl font-bold mb-6 text-blue-900">Skills</h3>
        <div class="grid md:grid-col-2 gap-6">
            <div>
                <h4 class="font-semibold mb-2">Technical Skills</h4>
                <p>Python, SQL, Data Cleaning, Machine Learning, NLP, Data Visualization</p>
            </div>
            <div>
